local function isMeleeWeapon(tool: Tool): boolean
	local typeAttrs: { string } = { "Type", "WeaponType", "Category", "Class", "ItemType", "ToolType" }
	for _, attrName: string in ipairs(typeAttrs) do
		local val: any = tool:GetAttribute(attrName)
		if val and type(val) == "string" then
			local lower: string = (val :: string):lower()
			if lower:find("melee") or lower:find("sword") or lower:find("knife") or lower:find("blunt") then
				return true
			end
			if lower:find("gun") or lower:find("ranged") or lower:find("firearm") or lower:find("projectile") then
				return false
			end
		end
	end

	for _, child: Instance in ipairs(tool:GetChildren()) do
		if child:IsA("StringValue") then
			local nameLower: string = child.Name:lower()
			if nameLower:find("type") or nameLower:find("category") or nameLower:find("class") then
				local valLower: string = child.Value:lower()
				if valLower:find("melee") or valLower:find("sword") or valLower:find("knife") or valLower:find("blunt") then
					return true
				end
				if valLower:find("gun") or valLower:find("ranged") or valLower:find("firearm") or valLower:find("projectile") then
					return false
				end
			end
		end
	end

	local nameToCheck: string = getDisplayName(tool):lower()
	local toolNameLower: string = tool.Name:lower()

	for _, keyword: string in ipairs(GUN_KEYWORDS) do
		if nameToCheck:find(keyword) or toolNameLower:find(keyword) then
			return false
		end
	end

	for _, keyword: string in ipairs(MELEE_KEYWORDS) do
		if nameToCheck:find(keyword) or toolNameLower:find(keyword) then
			return true
		end
	end

	for _, desc: Instance in ipairs(tool:GetDescendants()) do
		if desc:IsA("Script") or desc:IsA("LocalScript") or desc:IsA("ModuleScript") then
			local name: string = desc.Name:lower()
			if name:find("fire") or name:find("shoot") or name:find("bullet") or name:find("ammo") or name:find("gun") or name:find("reload") or name:find("recoil") then
				return false
			end
			if name:find("swing") or name:find("slash") or name:find("stab") or name:find("melee") then
				return true
			end
		end
	end

	return false
end

type ToolInfo = { name: string, rarity: string }

local function getToolList(targetPlayer: Player): { ToolInfo }
	local tools: { ToolInfo } = {}
	local seenNames: { [string]: boolean } = {}

	local function addTool(tool: Tool): ()
		local displayName: string = getDisplayName(tool)
		if seenNames[displayName] then
			return
		end
		seenNames[displayName] = true
		table.insert(tools, { name = displayName, rarity = getRarity(tool) })
	end

	-- 1) Equipped tool (in Character)
	local character: Model? = targetPlayer.Character
	if character then
		for _, child: Instance in ipairs(character:GetChildren()) do
			if child:IsA("Tool") then
				addTool(child :: Tool)
			end
		end
	end

	-- 2) Backpack
	local backpack: Backpack? = targetPlayer:FindFirstChildOfClass("Backpack")
	if backpack then
		for _, child: Instance in ipairs(backpack:GetChildren()) do
			if child:IsA("Tool") then
				addTool(child :: Tool)
			end
		end
	end

	-- 3) StarterGear (shows what the player spawned with)
	local starterGear: Instance? = targetPlayer:FindFirstChild("StarterGear")
	if starterGear then
		for _, child: Instance in ipairs(starterGear:GetChildren()) do
			if child:IsA("Tool") then
				addTool(child :: Tool)
			end
		end
	end

	-- 4) PlayerGui (some games store tool indicators here)
	-- Not adding items from PlayerGui since they aren't actual Tools

	return tools
end

local function createESP(targetPlayer: Player): ()
	if targetPlayer == player then
		return
	end
	if espElements[targetPlayer] then
		return
	end

	local character: Model? = targetPlayer.Character
	if not character then
		return
	end

	-- Highlight
	local highlight = Instance.new("Highlight")
	highlight.Name = "ESP_Highlight"
	highlight.Adornee = character
	highlight.FillColor = Color3.fromRGB(255, 100, 100)
	highlight.OutlineColor = Color3.fromRGB(255, 200, 200)
	highlight.FillTransparency = 0.55
	highlight.OutlineTransparency = 0.2
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent = character

	-- BillboardGui
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "ESP_Billboard"
	billboard.Size = UDim2.new(0, 150, 0, 50)
	billboard.StudsOffsetWorldSpace = Vector3.new(0, 3, 0)
	billboard.AlwaysOnTop = true
	billboard.ClipsDescendants = false

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "Name"
	nameLabel.Size = UDim2.new(1, 0, 0, 18)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = targetPlayer.Name
	nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	nameLabel.TextScaled = true
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextStrokeTransparency = 0.4
	nameLabel.Parent = billboard

	local statsLabel = Instance.new("TextLabel")
	statsLabel.Name = "Stats"
	statsLabel.Size = UDim2.new(1, 0, 0, 16)
	statsLabel.Position = UDim2.new(0, 0, 0, 18)
	statsLabel.BackgroundTransparency = 1
	statsLabel.Text = "HP: 100 | 0m"
	statsLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
	statsLabel.TextScaled = true
	statsLabel.Font = Enum.Font.GothamMedium
	statsLabel.TextStrokeTransparency = 0.5
	statsLabel.Parent = billboard

	local itemLabel = Instance.new("TextLabel")
	itemLabel.Name = "Item"
	itemLabel.Size = UDim2.new(1, 0, 0, 16)
	itemLabel.Position = UDim2.new(0, 0, 0, 34)
	itemLabel.BackgroundTransparency = 1
	itemLabel.Text = "None"
	itemLabel.TextColor3 = Color3.fromRGB(255, 200, 80)
	itemLabel.TextScaled = true
	itemLabel.RichText = true
	itemLabel.Font = Enum.Font.GothamMedium
	itemLabel.TextStrokeTransparency = 0.5
	itemLabel.Parent = billboard

	local head: BasePart? = character:FindFirstChild("Head")
	if head then
		billboard.Parent = head
	else
		local root: BasePart? = character:FindFirstChild("HumanoidRootPart")
		if root then
			billboard.StudsOffsetWorldSpace = Vector3.new(0, 0, 0)
			billboard.Parent = root
		end
	end

	espElements[targetPlayer] = {
		highlight = highlight,
		billboard = billboard,
		nameLabel = nameLabel,
		statsLabel = statsLabel,
		itemLabel = itemLabel,
	}

	-- If ESP is disabled, hide it immediately
	if not espEnabled then
		highlight.Enabled = false
		billboard.Enabled = false
	end
end

local function removeESP(targetPlayer: Player): ()
	local esp = espElements[targetPlayer]
	if not esp then
		return
	end

	esp.highlight:Destroy()
	esp.billboard:Destroy()
	espElements[targetPlayer] = nil
end

local function updateESP(): ()
	if not espEnabled then
		return
	end

	local cameraPos: Vector3 = camera.CFrame.Position

	for targetPlayer, esp in espElements do
		local character: Model? = targetPlayer.Character
		if not character then
			removeESP(targetPlayer)
			continue
		end

		local humanoid: Humanoid? = character:FindFirstChildOfClass("Humanoid")
		local head: BasePart? = character:FindFirstChild("Head")

		if not humanoid or not head then
			esp.statsLabel.Text = "HP: ? | Dist: ?"
			continue
		end

		-- Health + distance combined
		local health: number = math.floor(humanoid.Health + 0.5)
		local maxHealth: number = math.floor(humanoid.MaxHealth + 0.5)
		local dist: number = math.floor((head.Position - cameraPos).Magnitude + 0.5)
		esp.statsLabel.Text = "HP: " .. tostring(health) .. "/" .. tostring(maxHealth) .. " | " .. tostring(dist) .. "m"

		if health > 60 then
			esp.statsLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
		elseif health > 30 then
			esp.statsLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
		else
			esp.statsLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
		end

		-- Items: all weapons (not Common), show rarity instead of name
		local function collectWeaponRarities(): { string }
			local rarities: { string } = {}
			local seen: { [string]: boolean } = {}
			local function scanTools(container: Instance?): ()
				if not container then return end
				for _, child: Instance in ipairs(container:GetChildren()) do
					if child:IsA("Tool") then
						local tool: Tool = child :: Tool
						local rarity: string = getRarity(tool)
						if rarity ~= "Common" and not seen[rarity] then
							seen[rarity] = true
							table.insert(rarities, rarity)
						end
					end
				end
			end
			local character: Model? = targetPlayer.Character
			if character then scanTools(character) end
			local backpack: Backpack? = targetPlayer:FindFirstChildOfClass("Backpack")
			if backpack then scanTools(backpack) end
			local starterGear: Instance? = targetPlayer:FindFirstChild("StarterGear")
			if starterGear then scanTools(starterGear) end
			return rarities
		end

		local weaponRarities: { string } = collectWeaponRarities()
		if #weaponRarities == 0 then
			esp.itemLabel.Text = '<font color="#888888">Weapon:</font> None'
		else
			local display: string = '<font color="#888888">Weapon:</font> '
			for i = 1, math.min(#weaponRarities, 3) do
				if i > 1 then
					display ..= " | "
				end
				local rarity: string = weaponRarities[i]
				local color: Color3 = RARITY_COLORS[rarity] or RARITY_COLORS.Common
				local hex: string = string.format("#%02X%02X%02X", math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255))
				display ..= string.format('<font color="%s">%s</font>', hex, rarity)
			end
			if #weaponRarities > 3 then
				display ..= string.format(' <font color="#888888">+%d</font>', #weaponRarities - 3)
			end
			esp.itemLabel.Text = display
		end

		-- Re-parent billboard if character respawned
		if esp.billboard.Parent ~= head then
			esp.billboard.Parent = head
			esp.billboard.StudsOffsetWorldSpace = Vector3.new(0, 3.5, 0)
		end

		-- Update highlight Adornee if character changed
		if esp.highlight.Adornee ~= character then
			esp.highlight.Adornee = character
		end
	end
end

local function toggleESP(): ()
	espEnabled = not espEnabled
	if espEnabled then
		espBtn.BackgroundColor3 = GREEN_ON
		espBtn.TextColor3 = TEXT_WHITE
		espBtnStroke.Color = GREEN_ON_DARK
		espBtn.Text = "ESP: ON"
		local grad = espBtn:FindFirstChildOfClass("UIGradient")
		if not grad then
			grad = Instance.new("UIGradient")
			grad.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, Color3.fromRGB(90, 230, 130)),
				ColorSequenceKeypoint.new(1, Color3.fromRGB(50, 180, 90)),
			})
			grad.Rotation = 90
			grad.Parent = espBtn
		end
	else
		espBtn.BackgroundColor3 = RED_OFF
		espBtn.TextColor3 = TEXT_DIM
		espBtnStroke.Color = Color3.fromRGB(55, 55, 75)
		espBtn.Text = "ESP: OFF"
		local grad = espBtn:FindFirstChildOfClass("UIGradient")
		if grad then
			grad:Destroy()
		end
	end

	for _, esp in espElements do
		esp.highlight.Enabled = espEnabled
		esp.billboard.Enabled = espEnabled
	end
end

-- === Pick Items ===

local PICK_RADIUS: number = 80
local PICK_INTERVAL: number = 1

local droppedTools: { [Tool]: true } = {}
local itemsDirty: boolean = false

local function isDroppedTool(obj: Instance): boolean
	if not obj:IsA("Tool") then
		return false
	end
	local tool: Tool = obj :: Tool
	if not tool.Parent then
		return false
	end
	if tool.Parent == player.Character or tool.Parent == player:FindFirstChildOfClass("Backpack") then
		return false
	end
	if tool.Parent:IsA("Model") and playersService:GetPlayerFromCharacter(tool.Parent) then
		return false
	end
	return true
end

local function onDescendantAdded(obj: Instance): ()
	if not pickItemsEnabled then
		return
	end
	if isDroppedTool(obj) then
		droppedTools[obj :: Tool] = true
		itemsDirty = true
	end
end

local function onDescendantRemoving(obj: Instance): ()
	if obj:IsA("Tool") then
		droppedTools[obj :: Tool] = nil
	end
end

local function togglePickItems(): ()
	pickItemsEnabled = not pickItemsEnabled
	if pickItemsEnabled then
		pickItemsBtn.BackgroundColor3 = GREEN_ON
		pickItemsBtn.TextColor3 = TEXT_WHITE
		pickItemsBtnStroke.Color = GREEN_ON_DARK
		pickItemsBtn.Text = "Pick Items: ON"
		local grad = pickItemsBtn:FindFirstChildOfClass("UIGradient")
		if not grad then
			grad = Instance.new("UIGradient")
			grad.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, Color3.fromRGB(90, 230, 130)),
				ColorSequenceKeypoint.new(1, Color3.fromRGB(50, 180, 90)),
			})
			grad.Rotation = 90
			grad.Parent = pickItemsBtn
		end
		droppedTools = {}
		itemsDirty = false
		print("[PickItems] Enabled - auto-picking dropped items")
	else
		pickItemsBtn.BackgroundColor3 = RED_OFF
		pickItemsBtn.TextColor3 = TEXT_DIM
		pickItemsBtnStroke.Color = Color3.fromRGB(55, 55, 75)
		pickItemsBtn.Text = "Pick Items: OFF"
		local grad = pickItemsBtn:FindFirstChildOfClass("UIGradient")
		if grad then
			grad:Destroy()
		end
		droppedTools = {}
		print("[PickItems] Disabled")
	end
end

local function tryEquipClosest(): ()
	local character: Model? = player.Character
	if not character then
		return
	end
	local rootPart: BasePart? = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then
		return
	end
	local humanoid: Humanoid? = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return
	end
	local playerPos: Vector3 = rootPart.Position
	local closestTool: Tool? = nil
	local closestDist: number = math.huge
	for tool: Tool in pairs(droppedTools) do
		if not tool.Parent or not isDroppedTool(tool) then
			droppedTools[tool] = nil
			continue
		end
		local handle: BasePart? = tool:FindFirstChild("Handle")
		if not handle then
			continue
		end
		local dist: number = (handle.Position - playerPos).Magnitude
		if dist < closestDist and dist <= PICK_RADIUS then
			closestDist = dist
			closestTool = tool
		end
	end
	if closestTool then
		humanoid:EquipTool(closestTool)
	end
end

local function pickItemsLoop(): ()
	while pickItemsEnabled do
		if itemsDirty then
			itemsDirty = false
			tryEquipClosest()
		end
		task.wait(PICK_INTERVAL)
	end
end

