-- When new tools appear in workspace, add them to the item name cache
workspace.DescendantAdded:Connect(function(desc: Instance)
	if desc:IsA("Tool") then
		local toolName: string = desc.Name
		if tonumber(toolName) and not itemNameCache[toolName] then
			local tooltip: string = desc.ToolTip
			if tooltip ~= "" and not tonumber(tooltip) then
				itemNameCache[toolName] = tooltip
				return
			end
			for _, child: Instance in ipairs(desc:GetDescendants()) do
				if child:IsA("StringValue") then
					local val: string = child.Value
					if val ~= "" and not tonumber(val) then
						itemNameCache[toolName] = val
						return
					end
				end
			end
		end
	end
end)
