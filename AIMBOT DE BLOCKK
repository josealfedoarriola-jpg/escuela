local itemNameCache: { [string]: string } = {}
local itemNameCacheBuilt: boolean = false
local itemNameCacheLastBuilt: number = 0
local ITEM_CACHE_INTERVAL: number = 10

local function scanWorkspaceForItemNames(forceRebuild: boolean?): ()
	if not forceRebuild and itemNameCacheBuilt then
		return
	end
	itemNameCacheBuilt = true
	for _, obj: Instance in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Tool") then
			local toolName: string = obj.Name
			if tonumber(toolName) then
				-- Try ToolTip first
				local tooltip: string = obj.ToolTip
				if isValidName(tooltip) then
					itemNameCache[toolName] = tooltip
					continue
				end
				-- Try all StringValue descendants
				for _, desc: Instance in ipairs(obj:GetDescendants()) do
					if desc:IsA("StringValue") then
						local val: string = desc.Value
						if isValidName(val) then
							itemNameCache[toolName] = val
							break
						end
					end
				end
			end
		end
	end
	itemNameCacheBuilt = true
	itemNameCacheLastBuilt = tick()
end

local function getDisplayName(tool: Tool): string
	local toolName: string = tool.Name

	-- 1) Tool.ToolTip — Roblox officially uses this for hover names, games often set it
	local tooltip: string = tool.ToolTip
	if tooltip ~= "" and not tonumber(tooltip) and isValidName(tooltip) then
		return tooltip
	end

	-- 2) Check known-name attributes on the Tool
	local attrKeys: { string } = { "DisplayName", "ItemName", "WeaponName", "ToolName", "Name", "Title", "Label", "Item", "Weapon", "GearName" }
	for _, attrName: string in ipairs(attrKeys) do
		local val: any = tool:GetAttribute(attrName)
		if val and type(val) == "string" and isValidName(val :: string) and val ~= toolName then
			return val :: string
		end
	end

	-- 3) Broad attribute scan: any string attribute with a valid name
	local attributes: { string } = {}
	for attrName: string, _ in tool:GetAttributes() do
		table.insert(attributes, attrName)
	end
	for _, attrName: string in ipairs(attributes) do
		local val: any = tool:GetAttribute(attrName)
		if type(val) == "string" then
			local strVal: string = val :: string
			if isValidName(strVal) and strVal ~= toolName then
				return strVal
			end
		end
	end

	-- 4) Check StringValue descendants
	local bestCandidate: string? = nil
	for _, desc: Instance in ipairs(tool:GetDescendants()) do
		if desc:IsA("StringValue") then
			local val: string = desc.Value
			if isValidName(val) and val ~= toolName then
				local nameLower: string = desc.Name:lower()
				-- Prioritize name-related StringValues
				if nameLower:find("name") or nameLower:find("title") or nameLower:find("label")
					or nameLower:find("display") or nameLower:find("item")
				then
					return val
				end
				-- Keep first candidate found from non-name-related StringValues
				if not bestCandidate then
					bestCandidate = val
				end
			end
		end
	end
	if bestCandidate and isValidName(bestCandidate) then
		return bestCandidate
	end

	-- 5) Check Configuration folder for any valid StringValue
	local config: Instance? = tool:FindFirstChild("Configuration")
	if config then
		for _, child: Instance in ipairs(config:GetChildren()) do
			if child:IsA("StringValue") then
				local val: string = child.Value
				if isValidName(val) and val ~= toolName then
					return val
				end
			end
		end
	end

	-- 6) Handle might have a meaningful name
	local handle: BasePart? = tool:FindFirstChild("Handle")
	if handle and handle.Name ~= "Handle" and handle.Name ~= toolName and not tonumber(handle.Name) then
		return handle.Name
	end

	-- 7) Check Handle's children for decals/texture names
	if handle then
		for _, hChild: Instance in ipairs(handle:GetChildren()) do
			if hChild:IsA("Decal") or hChild:IsA("Texture") then
				-- Some games name the Decal with the weapon name
				if hChild.Name ~= "Decal" and hChild.Name ~= "Texture" and not tonumber(hChild.Name) then
					return hChild.Name
				end
			end
		end
	end

	-- 8) For numeric names, check our workspace item cache and ReplicatedStorage cache
	if tonumber(toolName) then
		-- Try workspace cache
		scanWorkspaceForItemNames()
		if itemNameCache[toolName] then
			return itemNameCache[toolName]
		end

		-- Try ReplicatedStorage module cache
		buildWeaponNameCache()
		if weaponNameCache[toolName] then
			return weaponNameCache[toolName]
		end
		if weaponNameCache[toolName:lower()] then
			return weaponNameCache[toolName:lower()]
		end

		-- Check if the Tool's ClassName or path gives us a hint
		-- Look at parent folder name
		if tool.Parent and tool.Parent.Name ~= "Backpack" and tool.Parent.Name ~= "Character"
			and not tonumber(tool.Parent.Name) then
			-- The parent folder might be named after the weapon category
			-- e.g., parent = "Swords" folder -> still not great, skip
		end

		return "Weapon #" .. toolName
	end

	-- 9) If Tool.Name is not numeric, clean it up
	local cleaned: string = toolName
	local prefixes: { string } = { "tools_cinder_", "tool_", "cinder_", "weapon_", "item_", "tools_", "gear_", "weapons_" }
	for _, prefix: string in ipairs(prefixes) do
		if cleaned:lower():sub(1, #prefix) == prefix then
			cleaned = cleaned:sub(#prefix + 1)
			break
		end
	end
	cleaned = cleaned:gsub("[_-]", " ")
	cleaned = cleaned:gsub("%s+", " ")
	cleaned = cleaned:sub(1, 1):upper() .. cleaned:sub(2)
	return cleaned
end

local function getRarity(tool: Tool): string
	-- Helper: match a rarity string against the known tiers
	local function matchRarity(text: string): string?
		if not text or text == "" then
			return nil
		end
		local r: string = text:sub(1, 1):upper() .. text:sub(2):lower()
		for _, tier: string in ipairs(RARITY_ORDER) do
			if r == tier then
				return tier
			end
		end
		-- Try partial match (e.g., "legend" matches "Legendary")
		local lower: string = text:lower()
		if lower:find("mythic") then return "Mythic" end
		if lower:find("legend") then return "Legendary" end
		if lower:find("epic") then return "Epic" end
		if lower:find("rare") then return "Rare" end
		if lower:find("uncommon") then return "Uncommon" end
		if lower:find("common") then return "Common" end
		return nil
	end

	local rarityNames: { string } = { "Rarity", "rarity", "Tier", "tier", "RarityType", "Quality", "Grade", "Rank" }

	-- 1) Check attributes on the Tool itself
	for _, attrName: string in ipairs(rarityNames) do
		local attr: any = tool:GetAttribute(attrName)
		if attr then
			if type(attr) == "string" then
				local m: string? = matchRarity(attr :: string)
				if m then return m end
			elseif type(attr) == "number" then
				local tierIndex: number = math.clamp(math.floor(attr :: number + 0.5), 1, #RARITY_ORDER)
				return RARITY_ORDER[tierIndex]
			end
		end
	end

	-- 2) Check direct children (StringValue, IntValue, etc.)
	for _, child: Instance in ipairs(tool:GetChildren()) do
		for _, rName: string in ipairs(rarityNames) do
			if child.Name == rName then
				if child:IsA("StringValue") then
					local m: string? = matchRarity(child.Value)
					if m then return m end
				elseif child:IsA("IntValue") or child:IsA("NumberValue") then
					local tierIndex: number = math.clamp(math.floor(child.Value + 0.5), 1, #RARITY_ORDER)
					return RARITY_ORDER[tierIndex]
				end
			end
		end
	end

	-- 3) Check Configuration folder descendants
	local config: Instance? = tool:FindFirstChild("Configuration")
	if config then
		for _, desc: Instance in ipairs(config:GetDescendants()) do
			for _, rName: string in ipairs(rarityNames) do
				if desc.Name == rName then
					if desc:IsA("StringValue") then
						local m: string? = matchRarity(desc.Value)
						if m then return m end
					elseif desc:IsA("IntValue") or desc:IsA("NumberValue") then
						local tierIndex: number = math.clamp(math.floor(desc.Value + 0.5), 1, #RARITY_ORDER)
						return RARITY_ORDER[tierIndex]
					end
				end
			end
			-- Also check attributes on Configuration descendants
			if desc:IsA("Configuration") or desc:IsA("Folder") then
				for _, attrName: string in ipairs(rarityNames) do
					local attr: any = desc:GetAttribute(attrName)
					if attr and type(attr) == "string" then
						local m: string? = matchRarity(attr :: string)
						if m then return m end
					end
				end
			end
		end
	end

	-- 4) Check ALL descendants of the tool (deeper search for nested values)
	for _, desc: Instance in ipairs(tool:GetDescendants()) do
		for _, rName: string in ipairs(rarityNames) do
			if desc.Name == rName then
				if desc:IsA("StringValue") then
					local m: string? = matchRarity(desc.Value)
					if m then return m end
				elseif desc:IsA("IntValue") or desc:IsA("NumberValue") then
					local tierIndex: number = math.clamp(math.floor(desc.Value + 0.5), 1, #RARITY_ORDER)
					return RARITY_ORDER[tierIndex]
				end
			end
		end
		-- Check attributes on any descendant
		for _, attrName: string in ipairs(rarityNames) do
			local attr: any = desc:GetAttribute(attrName)
			if attr and type(attr) == "string" then
				local m: string? = matchRarity(attr :: string)
				if m then return m end
			end
		end
	end

	-- 5) Fallback: guess from display name keywords
	local nameToSearch: string = tool.Name
	if tonumber(nameToSearch) then
		nameToSearch = getDisplayName(tool)
	end
	local lower: string = nameToSearch:lower()
	if lower:find("mythic") then return "Mythic" end
	if lower:find("legend") then return "Legendary" end
	if lower:find("epic") then return "Epic" end
	if lower:find("rare") then return "Rare" end
	if lower:find("uncommon") then return "Uncommon" end

	return "Common"
end

