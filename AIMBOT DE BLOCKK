local function refreshPlayerList(): ()
	for _, child in ipairs(playerScroll:GetChildren()) do
		if child:IsA("TextButton") then
			child:Destroy()
		end
	end

	local players: { Player } = playersService:GetPlayers()
	local yPos: number = 0

	for _, p: Player in ipairs(players) do
		if p == player then
			continue
		end

		local isExcluded: boolean = excludedPlayers[p] == true
		local btnColor: Color3 = isExcluded and Color3.fromRGB(120, 45, 45) or Color3.fromRGB(48, 48, 64)
		local btnTextColor: Color3 = isExcluded and Color3.fromRGB(255, 120, 120) or TEXT_WHITE
		local btnText: string = p.Name .. (isExcluded and " [EXCLUDED]" or "")

		local playerBtn = Instance.new("TextButton")
		playerBtn.Name = p.Name
		playerBtn.Size = UDim2.new(1, -6, 0, 30)
		playerBtn.Position = UDim2.new(0, 3, 0, yPos)
		playerBtn.BackgroundColor3 = btnColor
		playerBtn.Text = btnText
		playerBtn.TextColor3 = btnTextColor
		playerBtn.TextScaled = true
		playerBtn.Font = Enum.Font.GothamMedium
		playerBtn.BorderSizePixel = 0
		playerBtn.TextXAlignment = Enum.TextXAlignment.Left
		playerBtn.Parent = playerScroll

		local btnCorner = Instance.new("UICorner")
		btnCorner.CornerRadius = UDim.new(0, 6)
		btnCorner.Parent = playerBtn

		local btnStroke = Instance.new("UIStroke")
		btnStroke.Color = isExcluded and Color3.fromRGB(160, 50, 50) or Color3.fromRGB(60, 60, 80)
		btnStroke.Thickness = 1
		btnStroke.Transparency = 0.4
		btnStroke.Parent = playerBtn

		playerBtn.MouseButton1Click:Connect(function()
			if excludedPlayers[p] then
				excludedPlayers[p] = nil
			else
				excludedPlayers[p] = true
			end
			refreshPlayerList()
		end)

		yPos += 36
	end

	playerScroll.CanvasSize = UDim2.new(0, 0, 0, yPos + 4)
end

