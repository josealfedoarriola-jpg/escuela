-- Helper: validates whether a string looks like a real item/weapon name
local function isValidName(text: string): boolean
	if text == "" or tonumber(text) then
		return false
	end

	local lower: string = text:lower()

	-- Reject common "no item" messages
	if lower:find("nuthin") or lower:find("nothing") or lower:find("empty") or lower:find("none") then
		return false
	end
	if lower:find("i have") or lower:find("you have") or lower:find("don'") then
		return false
	end

	-- Reject Roblox asset IDs (rbxassetid://... or rbxasset://...)
	if lower:find("rbxassetid://") or lower:find("rbxasset://") then
		return false
	end

	-- Reject text that looks like a UI message (more than 3 words)
	local _, wordCount = text:gsub("%S+", "")
	if wordCount > 3 then
		return false
	end

	-- Reject strings with excessive character repetition (e.g. "nnnnnnnnnggg")
	local longestRepeat: number = 0
	local currentChar: string = ""
	local currentCount: number = 0
	for char in text:gmatch(".") do
		local c: string = char:lower()
		if c == currentChar then
			currentCount += 1
		else
			currentChar = c
			currentCount = 1
		end
		if currentCount > longestRepeat then
			longestRepeat = currentCount
		end
	end
	if longestRepeat > 5 then
		return false
	end

	return true
end

-- Cache for weapon name lookups from ReplicatedStorage modules (avoids repeated deep scans)
local weaponNameCache: { [string]: string } = {}
local weaponCacheBuilt: boolean = false
local weaponCacheLastBuilt: number = 0
local WEAPON_CACHE_INTERVAL: number = 10

local function buildWeaponNameCache(forceRebuild: boolean?): ()
	if not forceRebuild and weaponCacheBuilt then
		return
	end

	-- Scan ReplicatedStorage for ModuleScripts that might contain weapon name data
	local foldersToSearch: { Instance } = { replicatedStorage }

	-- Common folder names where games store weapon data
	for _, folderName: string in ipairs({ "Weapons", "Items", "Tools", "Guns", "Swords", "WeaponData", "ItemData", "ToolData", "Configs", "Config", "Data", "Shared", "Modules" }) do
		local folder: Instance? = replicatedStorage:FindFirstChild(folderName)
		if folder then
			table.insert(foldersToSearch, folder)
		end
	end

	for _, parent: Instance in ipairs(foldersToSearch) do
		for _, desc: Instance in ipairs(parent:GetDescendants()) do
			-- ModuleScripts named like weapon configs (e.g., "1", "Sword", etc.)
			-- Also check for RemoteEvents/RemoteFunctions that might be named like "Equip_WeaponName"
			if desc:IsA("ModuleScript") or desc:IsA("RemoteEvent") or desc:IsA("RemoteFunction") then
				local dName: string = desc.Name
				-- Normalize the key: strip common prefix patterns
				local key: string = dName:lower()
				key = key:gsub("^(equip%s*[_%s]*)", "")
				key = key:gsub("^(unlock%s*[_%s]*)", "")
				key = key:gsub("^(buy%s*[_%s]*)", "")
				key = key:gsub("^(get%s*[_%s]*)", "")

				-- Only store non-numeric meaningful names
				if not tonumber(key) and key ~= "" then
					weaponNameCache[key] = dName
					-- Also store by the original name
					weaponNameCache[dName] = dName
				end
			end

			-- StringValue children that might map IDs to names
			if desc:IsA("StringValue") then
				local val: string = desc.Value
				if isValidName(val) then
					-- Map by parent name and by own name
					if desc.Parent then
						weaponNameCache[desc.Parent.Name:lower()] = val
						weaponNameCache[desc.Parent.Name] = val
					end
					weaponNameCache[desc.Name:lower()] = val
					weaponNameCache[desc.Name] = val
				end
			end
		end
	end
	weaponCacheBuilt = true
	weaponCacheLastBuilt = tick()
end

